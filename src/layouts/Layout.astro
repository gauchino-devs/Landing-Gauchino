---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParticlesBackground from '../components/ParticlesBackground.astro';
import '../styles/global.css';
import 'aos/dist/aos.css';

interface Props { title?: string; hasHero?: boolean; }
const { title = 'Gauchino', hasHero = false } = Astro.props;
const lang = Astro.currentLocale ?? 'es';
---
<!doctype html>
<html lang={lang} class:list={[hasHero && 'has-hero-anim']}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon-32x32.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Particles canvas: fixed, z-index 0, behind everything -->
    <ParticlesBackground />

    <!-- Wrapper elevates all visible content above the canvas -->
    <div class="layout-wrapper">
      <Navbar />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import AOS from 'aos';
      AOS.init({
        duration: 700,
        easing: 'ease-out-cubic',
        once: true,
        offset: 60,
      });
    </script>

    <a
      href="https://wa.me/5491140232475"
      target="_blank"
      rel="noopener noreferrer"
      class="wpp-btn"
      aria-label="Contactar por WhatsApp"
    >
      <img src="/wppiconn.png" alt="WhatsApp" />
    </a>
  </body>
</html>

<style>
  /* Dark background lives on the body — canvas draws transparently on top of it */
  body {
    background-color: var(--color-primary);
  }

  /* This wrapper creates a stacking context above the canvas (z-index 0) */
  .layout-wrapper {
    position: relative;
    z-index: 1;
  }

  /* Main is transparent so sections without explicit backgrounds show the particles */
  main {
    background: transparent;
  }

  /* WhatsApp float — z-index high enough to always be on top */
  .wpp-btn {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 999;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background-color: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }

  .wpp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 22px rgba(37, 211, 102, 0.65);
  }

  .wpp-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
