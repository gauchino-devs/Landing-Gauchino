---
import { useTranslations } from '../i18n/utils';
const lang = Astro.currentLocale ?? 'es';
const t = useTranslations(lang);

// Prefijo de ruta segΓΊn el idioma actual
const prefix = lang === 'en' ? '/en' : lang === 'pt' ? '/pt' : '';

// URLs de cada sección
const href = {
  home:       prefix + '/',
  servicios:  prefix + '/#servicios',
  soluciones: prefix + '/#soluciones',
  clientes:   prefix + '/#clientes',
  contacto:   prefix + '/#contacto',
  cotizar:    prefix + '/cotizar',
};

// URLs de cambio de idioma (misma página, distinto locale)
const pathWithoutLocale = Astro.url.pathname
  .replace(/^\/en(\/|$)/, '/')
  .replace(/^\/pt(\/|$)/, '/');

const localeUrls = {
  es: pathWithoutLocale,
  en: '/en' + (pathWithoutLocale === '/' ? '/' : pathWithoutLocale),
  pt: '/pt' + (pathWithoutLocale === '/' ? '/' : pathWithoutLocale),
};

const langLabel = lang.toUpperCase();
---
<header class="navbar">
  <div class="navbar__container">
    <a href={href.home} class="navbar__logo">
      <img class="navbar__logo-icon" src="/logonavbar.png" alt="Gauchino Logo">
    </a>
    <nav class="navbar__nav">
      <a href={href.servicios}>{t['nav.servicios']}</a>
      <a href={href.soluciones}>{t['nav.soluciones']}</a>
      <a href={href.clientes}>{t['nav.clientes']}</a>
      <a href={href.contacto}>{t['nav.contacto']}</a>
    </nav>
    <div class="navbar__actions">
      <div class="lang-selector">
        <button class="lang-selector__btn" aria-haspopup="listbox" aria-expanded="false">
          <span class="lang-selector__icon">&#127760;</span>
          <span class="lang-selector__label">{langLabel}</span>
          <svg class="lang-selector__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="lang-selector__dropdown" role="listbox">
          <li class={`lang-selector__option${lang === 'es' ? ' lang-selector__option--active' : ''}`}>
            <a href={localeUrls.es}>&#127466;&#127480; Espa&#241;ol</a>
          </li>
          <li class={`lang-selector__option${lang === 'en' ? ' lang-selector__option--active' : ''}`}>
            <a href={localeUrls.en}>&#127482;&#127480; English</a>
          </li>
          <li class={`lang-selector__option${lang === 'pt' ? ' lang-selector__option--active' : ''}`}>
            <a href={localeUrls.pt}>&#127463;&#127479; Portugu&#234;s</a>
          </li>
        </ul>
      </div>
      <a href={href.cotizar} class="navbar__cta">{t['nav.cotizar']}</a>
    </div>

    <!-- Hamburger (mobile only) -->
    <label class="hamburger">
      <input type="checkbox" id="hamburger-check" />
      <svg viewBox="0 0 32 32">
        <path class="line line-top-bottom" d="M27 10 13 10C10.8 10 9 8.2 9 6 9 3.5 10.8 2 13 2 15.2 2 17 3.8 17 6L17 26C17 28.2 18.8 30 21 30 23.2 30 25 28.2 25 26 25 23.8 23.2 22 21 22L7 22"></path>
        <path class="line" d="M7 16 27 16"></path>
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-menu__nav">
      <a href={href.servicios}>{t['nav.servicios']}</a>
      <a href={href.soluciones}>{t['nav.soluciones']}</a>
      <a href={href.clientes}>{t['nav.clientes']}</a>
      <a href={href.contacto}>{t['nav.contacto']}</a>
    </nav>
    <a href={href.cotizar} class="navbar__cta mobile-menu__cta">{t['nav.cotizar']}</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background-color: var(--color-primary);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .navbar__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }
  .navbar__logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    gap: 0.5rem;
    letter-spacing: -0.02em;
  }
  .navbar__logo-icon { font-size: 1.4rem; width: 30vh; }
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    justify-content: center;
  }
  .navbar__actions {
    display: flex;
    justify-content: flex-end;
  }
  .navbar__nav a {
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .navbar__nav a:hover { color: #fff; }
  
  .navbar__cta {
    background-color: var(--color-secondary);
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius);
    font-weight: 500 !important;
    transition: background-color 0.2s !important;
  }
  .navbar__cta:hover { background-color: var(--color-secondary-hover) !important; }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    cursor: pointer;
  }

  .hamburger input {
    display: none;
  }

  .hamburger svg {
    height: 2.2em;
    transition: transform 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .line {
    fill: none;
    stroke: white;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 3;
    transition: stroke-dasharray 600ms cubic-bezier(0.4, 0, 0.2, 1),
                stroke-dashoffset 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .line-top-bottom {
    stroke-dasharray: 12 63;
  }

  .hamburger input:checked + svg {
    transform: rotate(-45deg);
  }

  .hamburger input:checked + svg .line-top-bottom {
    stroke-dasharray: 20 300;
    stroke-dashoffset: -32.42;
  }

  /* ── Mobile menu ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0;
    background-color: var(--color-primary);
    overflow: hidden;
    max-height: 0;
    padding: 0 2rem;
    transition: max-height 0.35s ease, padding 0.35s ease;
  }

  .mobile-menu.is-open {
    max-height: 400px;
    padding: 1.25rem 2rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .mobile-menu__nav a {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .mobile-menu__nav a:hover { color: #fff; }

  .mobile-menu__cta {
    align-self: flex-start;
  }

  @media (max-width: 768px) {
    .navbar__nav {
      display: none;
    }

    .navbar__cta:not(.mobile-menu__cta) {
      display: none;
    }

    .hamburger {
      display: block;
    }

    .mobile-menu {
      display: flex;
    }

    .navbar__container {
      grid-template-columns: 1fr auto auto;
    }
  }
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .lang-selector {
    position: relative;
  }

  .lang-selector__btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius);
    color: rgba(255,255,255,0.85);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.45rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .lang-selector__btn:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.35);
    color: #fff;
  }

  .lang-selector__arrow {
    transition: transform 0.2s;
  }

  .lang-selector--open .lang-selector__arrow {
    transform: rotate(180deg);
  }

  .lang-selector__dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--color-primary-light);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius);
    list-style: none;
    padding: 0.4rem 0;
    min-width: 150px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    z-index: 200;
  }

  .lang-selector--open .lang-selector__dropdown {
    display: block;
  }

  .lang-selector__option {
    padding: 0;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .lang-selector__option a {
    display: block;
    padding: 0.55rem 1rem;
    color: inherit;
    text-decoration: none;
    width: 100%;
  }

  .lang-selector__option:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  .lang-selector__option--active {
    color: var(--color-white);
    background-color: var(--color-secondary);
    font-weight: 600;
  }
</style>

<script>
  const selector = document.querySelector('.lang-selector')!;
  const btn      = selector.querySelector('.lang-selector__btn')!;

  // Hamburger toggle
  const hamburgerCheck = document.getElementById('hamburger-check') as HTMLInputElement;
  const mobileMenu = document.getElementById('mobile-menu')!;

  hamburgerCheck?.addEventListener('change', () => {
    mobileMenu.classList.toggle('is-open', hamburgerCheck.checked);
  });

  // Close mobile menu when a link is clicked
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburgerCheck.checked = false;
      mobileMenu.classList.remove('is-open');
    });
  });

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = selector.classList.toggle('lang-selector--open');
    btn.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', () => {
    selector.classList.remove('lang-selector--open');
    btn.setAttribute('aria-expanded', 'false');
  });
</script>
