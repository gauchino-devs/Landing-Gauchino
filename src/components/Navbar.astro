---
// Navbar component
---
<header class="navbar">
  <div class="navbar__container">
    <a href="/" class="navbar__logo">
      <img class="navbar__logo-icon" src="/logotipo_principal.svg" alt="Gauchino Logo">
    </a>
    <nav class="navbar__nav">
      <a href="/#servicios">Servicios</a>
      <a href="/#soluciones">Soluciones</a>
      <a href="/#clientes">Clientes</a>
      <a href="/#contacto">Contacto</a>
    </nav>
    <div class="navbar__actions">
      <div class="lang-selector">
        <button class="lang-selector__btn" aria-haspopup="listbox" aria-expanded="false">
          <span class="lang-selector__icon">&#127760;</span>
          <span class="lang-selector__label">ES</span>
          <svg class="lang-selector__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="lang-selector__dropdown" role="listbox">
          <li class="lang-selector__option lang-selector__option--active" data-lang="ES">&#127466;&#127480; Español</li>
          <li class="lang-selector__option" data-lang="EN">&#127482;&#127480; English</li>
          <li class="lang-selector__option" data-lang="PT">&#127463;&#127479; Português</li>
        </ul>
      </div>
      <a href="/cotizar" class="navbar__cta">Cotizar</a>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background-color: var(--color-primary);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .navbar__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }
  .navbar__logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    gap: 0.5rem;
    letter-spacing: -0.02em;
  }
  .navbar__logo-icon { font-size: 1.4rem; width: 30vh; }
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    justify-content: center;
  }
  .navbar__actions {
    display: flex;
    justify-content: flex-end;
  }
  .navbar__nav a {
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .navbar__nav a:hover { color: #fff; }
  
  .navbar__cta {
    background-color: var(--color-secondary);
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius);
    font-weight: 500 !important;
    transition: background-color 0.2s !important;
  }
  .navbar__cta:hover { background-color: var(--color-secondary-hover) !important; }

  /* ── Language selector ── */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .lang-selector {
    position: relative;
  }

  .lang-selector__btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius);
    color: rgba(255,255,255,0.85);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.45rem 0.75rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .lang-selector__btn:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.35);
    color: #fff;
  }

  .lang-selector__arrow {
    transition: transform 0.2s;
  }

  .lang-selector--open .lang-selector__arrow {
    transform: rotate(180deg);
  }

  .lang-selector__dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--color-primary-light);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius);
    list-style: none;
    padding: 0.4rem 0;
    min-width: 150px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    z-index: 200;
  }

  .lang-selector--open .lang-selector__dropdown {
    display: block;
  }

  .lang-selector__option {
    padding: 0.55rem 1rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .lang-selector__option:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  .lang-selector__option--active {
    color: var(--color-white);
    background-color: var(--color-secondary);
    font-weight: 600;
  }
</style>

<script>
  const selector = document.querySelector('.lang-selector')!;
  const btn      = selector.querySelector('.lang-selector__btn')!;
  const label    = selector.querySelector('.lang-selector__label')!;
  const options  = selector.querySelectorAll('.lang-selector__option');

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = selector.classList.toggle('lang-selector--open');
    btn.setAttribute('aria-expanded', String(open));
  });

  options.forEach(opt => {
    opt.addEventListener('click', () => {
      label.textContent = (opt as HTMLElement).dataset.lang ?? 'ES';
      options.forEach(o => o.classList.remove('lang-selector__option--active'));
      opt.classList.add('lang-selector__option--active');
      selector.classList.remove('lang-selector--open');
      btn.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('click', () => {
    selector.classList.remove('lang-selector--open');
    btn.setAttribute('aria-expanded', 'false');
  });
</script>
