<div class="soluciones-container">
  <div class="cuadro-principal">
    <div class="lado-izquierdo">
      <div class="lado-izquierdo-contenido">
        <h2 class="soluciones-titulo">El software correcto <span class="soluciones-highlight">cambia negocios</span></h2>
        <p class="soluciones-subtitulo">En Gauchino desarrollamos sistemas a medida que automatizan procesos, optimizan tiempos y centralizan la gestión del negocio.</p>
        <p class="soluciones-desc">Organizá tu negocio de forma simple y clara. Nuestro sistema permite registrar movimientos, mantener el stock actualizado y tener control total sobre los productos para evitar errores, faltantes y desorden.</p>
      </div>
    </div>
    <div class="lado-derecho">
      <div class="carousel">
        <div class="carousel-track">
          <img class="carousel-img" src="/stockeate.webp" alt="Stockeate" />
          <img class="carousel-img" src="/presupuestate.webp" alt="Presupuestate" />
          <img class="carousel-img" src="/flexus.webp" alt="Flexus" />
        </div>
        <button class="carousel-btn carousel-btn--prev" aria-label="Anterior">
          <img src="/arrow_back.svg" alt="Anterior" />
        </button>
        <button class="carousel-btn carousel-btn--next" aria-label="Siguiente">
          <img src="/arrow_forward.svg" alt="Siguiente" />
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const track = document.querySelector('.carousel-track') as HTMLElement;
  const imgs = document.querySelectorAll('.carousel-img');
  const desc = document.querySelector('.soluciones-desc') as HTMLElement;
  let current = 0;

  const textos = [
    'Organizá tu negocio de forma simple y clara. Nuestro sistema permite registrar movimientos, mantener el stock actualizado y tener control total sobre los productos para evitar errores, faltantes y desorden.',
    'Simplicá el proceso de ventas y digitalizá la información de tus clientes. Automatizamos tareas repetitivas y clasificamos datos para que puedas gestionar oportunidades, hacer seguimiento y vender de manera más eficiente.',
    'Centralizá la información clave y proyectá tus gastos. Presupuestá tu desarrollo inmobiliario, administrá tu base de clientes y organizá pagos o comisiones desde un mismo sistema pensado para simplificar la gestión diaria.',
  ];

  function goTo(index: number) {
    current = (index + imgs.length) % imgs.length;
    track.style.transform = `translateX(-${current * 100}%)`;
    desc.style.opacity = '0';
    setTimeout(() => {
      desc.textContent = textos[current];
      desc.style.opacity = '1';
    }, 200);
  }

  document.querySelector('.carousel-btn--prev')?.addEventListener('click', () => goTo(current - 1));
  document.querySelector('.carousel-btn--next')?.addEventListener('click', () => goTo(current + 1));
</script>

