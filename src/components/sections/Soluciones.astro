---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
const textos = [t['sol.desc1'], t['sol.desc2'], t['sol.desc3']];
---
<div class="soluciones-container" id="soluciones">
  <div class="cuadro-principal">
    <div class="lado-izquierdo" data-aos="fade-right" data-aos-duration="800">
      <div class="lado-izquierdo-contenido">
        <h2 class="soluciones-titulo">{t['sol.title1']} <span class="soluciones-highlight">{t['sol.title2']}</span></h2>
        <p class="soluciones-subtitulo">{t['sol.subtitle']}</p>
        <p class="soluciones-desc">{t['sol.desc1']}</p>
      </div>
    </div>
    <div class="lado-derecho" data-aos="fade-left" data-aos-duration="800" data-aos-delay="150">
      <div class="carousel">
        <div class="carousel-track">
          <img class="carousel-img" src="/stockeate.webp" alt="Stockeate" />
          <img class="carousel-img" src="/presupuestate.webp" alt="Presupuestate" />
          <img class="carousel-img" src="/flexus.webp" alt="Flexus" />
        </div>
        <button class="carousel-btn carousel-btn--prev" aria-label={t['sol.prev']}>
          <img src="/arrow_back.svg" alt={t['sol.prev']} />
        </button>
        <button class="carousel-btn carousel-btn--next" aria-label={t['sol.next']}>
          <img src="/arrow_forward.svg" alt={t['sol.next']} />
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ textos }}>
  const track = document.querySelector('.carousel-track');
  const imgs = document.querySelectorAll('.carousel-img');
  const desc = document.querySelector('.soluciones-desc');
  let current = 0;

  function goTo(index) {
    current = (index + imgs.length) % imgs.length;
    track.style.transform = `translateX(-${current * 100}%)`;
    desc.style.opacity = '0';
    setTimeout(() => {
      desc.textContent = textos[current];
      desc.style.opacity = '1';
    }, 200);
  }

  document.querySelector('.carousel-btn--prev')?.addEventListener('click', () => goTo(current - 1));
  document.querySelector('.carousel-btn--next')?.addEventListener('click', () => goTo(current + 1));
</script>

<style>
  .soluciones-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    min-height: 100vh;
  }

  .cuadro-principal {
    background-color: var(--color-primary);
    border-radius: var(--radius);
    width: 100%;
    height: 90vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .lado-izquierdo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
  }

  .lado-izquierdo-contenido {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .soluciones-titulo {
    color: var(--color-white);
    font-size: 2.4rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .soluciones-highlight {
    color: var(--color-secondary);
  }

  .soluciones-subtitulo {
    color: var(--color-secondary-light);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .soluciones-desc {
    color: var(--color-white);
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .lado-derecho {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    position: relative;
  }

  .lado-derecho::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100rem;
    height: 20rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(80px);
    opacity: 0.3;
    pointer-events: none;
    z-index: 0;
  }

  .carousel {
    position: relative;
    background-color: var(--color-primary-light);
    border-radius: var(--radius);
    width: 85%;
    height: 80%;
    overflow: hidden;
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .carousel-img {
    min-width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    pointer-events: none;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(70, 1, 250, 0.35);
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: rgba(70, 1, 250, 0.65);
  }

  .carousel-btn--prev { left: 0.75rem; }
  .carousel-btn--next { right: 0.75rem; }

  .carousel-btn img {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .soluciones-container {
      padding: 1rem;
    }

    .cuadro-principal {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }

    .lado-izquierdo {
      padding: 2rem 1.5rem 1rem;
    }

    .soluciones-titulo {
      font-size: 1.8rem;
      text-align: center;
    }

    .lado-derecho {
      padding: 1rem 1.5rem 2rem;
    }

    .carousel {
      width: 100%;
      height: 280px;
    }
  }

  @media (max-width: 480px) {
    .lado-izquierdo {
      padding: 1.5rem 1rem 0.75rem;
    }

    .soluciones-titulo {
      font-size: 1.5rem;
    }

    .lado-derecho {
      padding: 0.75rem 1rem 1.5rem;
    }

    .carousel {
      height: 220px;
    }
  }

  @media (min-width: 1440px) {
    .soluciones-container {
      max-width: 1380px;
      margin: 0 auto;
    }

    .cuadro-principal { max-width: 1380px; }
    .soluciones-titulo { font-size: 3rem; }
    .soluciones-subtitulo { font-size: 1.1rem; }
    .soluciones-desc { font-size: 1.1rem; }
  }
</style>