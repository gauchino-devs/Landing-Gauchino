---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
const cotizarHref = Astro.currentLocale === 'en' ? '/en/cotizar' : Astro.currentLocale === 'pt' ? '/pt/cotizar' : '/cotizar';
const serviciosHref = Astro.currentLocale === 'en' ? '/en/#servicios' : Astro.currentLocale === 'pt' ? '/pt/#servicios' : '/#servicios';
const contactoHref = Astro.currentLocale === 'en' ? '/en/#contacto' : Astro.currentLocale === 'pt' ? '/pt/#contacto' : '/#contacto';
---
<section id="hero" class="hero">
  <div class="hero__container">
    <div class="hero__content" data-aos="fade-right" data-aos-duration="800">
      <h1 class="hero__title">
        {t['hero.title1']}<br />
        <span class="hero__title--accent">{t['hero.title2']}</span>
      </h1>
      <p class="hero__subtitle" data-aos="fade-right" data-aos-delay="150">
        {t['hero.subtitle']}
      </p>
      <div class="hero__actions" data-aos="fade-right" data-aos-delay="250">
        <a href={cotizarHref} class="btn btn--primary">{t['hero.cta1']}</a>
        <a href={contactoHref} class="btn btn--outline">{t['hero.cta2']}</a>
      </div>
      <div class="hero__stats" data-aos="fade-up" data-aos-delay="350">
        <div class="hero__stat"><strong>{t['hero.stat1.value']}</strong><span>{t['hero.stat1.label']}</span></div>
        <div class="hero__stat"><strong>{t['hero.stat2.value']}</strong><span>{t['hero.stat2.label']}</span></div>
        <div class="hero__stat"><strong>{t['hero.stat3.value']}</strong><span>{t['hero.stat3.label']}</span></div>
      </div>
    </div>
    <div class="hero__image" data-aos="fade-left" data-aos-duration="900" data-aos-delay="100">
      <img src="/bannerbg.png" alt="Banner Gauchino" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background-color: var(--color-white);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* Columna izquierda: contenido hacia abajo */
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.5rem;
    padding: 8rem 2rem 8rem 1rem;
    padding-left: max(2rem, calc((90vw - var(--max-width)) / 2));
  }

  /* Columna derecha: imagen pegada abajo */
  .hero__image {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }

  .hero__image img {
    height: 90vh;
    width: auto;
    max-width: none;
    object-fit: contain;
    object-position: bottom center;
    display: block;
  }

  /* Elimina el wrapper .hero__container del flujo, ya no lo necesitamos */
  .hero__container {
    display: contents;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: auto;
    }
    .hero__content {
      padding: 7rem 1.5rem 3rem;
    }
    .hero__image {
      display: none;
    }
  }

  .hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    color: var(--color-secondary-light);
    font-size: 0.85rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.2);
    width: fit-content;
  }

  .hero__title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .hero__title--accent { color: var(--color-secondary); }

  .hero__subtitle {
    font-size: 1.125rem;
    color: var(--color-primary-light);
    max-width: 560px;
    line-height: 1.7;
  }

  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn--primary { background-color: var(--color-secondary); color: #fff; }

  .btn--primary:hover { background-color: var(--color-secondary-hover); transform: translateY(-1px); }

  .btn--outline { border: 2px solid var(--color-secondary); color: var(--color-primary); }

  .btn--outline:hover { background: var(--color-secondary); color: var(--color-white); transform: translateY(-1px); }

  .hero__stats {
    display: flex;
    gap: 3rem;
    padding-top: 1rem;
    flex-wrap: wrap;
  }

  .hero__stat { display: flex; flex-direction: column; }

  .hero__stat strong { font-size: 2rem; font-weight: 700; color: var(--color-secondary-light); line-height: 1; }

  .hero__stat span  { font-size: 0.85rem; color: var(--color-primary-light); margin-top: 0.25rem; }
</style>
