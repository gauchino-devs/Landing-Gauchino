---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
const cotizarHref = Astro.currentLocale === 'en' ? '/en/cotizar' : Astro.currentLocale === 'pt' ? '/pt/cotizar' : '/cotizar';
---
<section id="contacto">
<h2 class="contacto-title" data-aos="fade-up">{t['con.title']}</h2>
<h4 class="contacto-subtitle" data-aos="fade-up" data-aos-delay="100">
    {t['con.subtitle']} <br /> {t['con.subtitle2']}
</h4>
<div class="contacto-container">
  <!-- Parte Inferior -->
  <div class="parte-inferior">
    <!-- Izquierda - Formulario -->
    <div class="formulario" data-aos="fade-right" data-aos-delay="150">
      <input type="text" placeholder={t['con.name']} />
      <input type="email" placeholder={t['con.email']} />
      <textarea placeholder={t['con.message']}></textarea>
      <button>{t['con.send']}</button>
    </div>
    
    <!-- Derecha - Tres Cuadros -->
    <div class="cuadros-derecha" data-aos="fade-left" data-aos-delay="200">
      <div class="cuadro">
        <span class="cuadro-label">Email</span>
        <span class="cuadro-valor">informacion@gauchino.com</span>
      </div>
      <div class="cuadro">
        <span class="cuadro-label">{t['con.resp.label']}</span>
        <span class="cuadro-valor">{t['con.resp.value']}</span>
      </div>
      <div class="cuadro cuadro-cta">
        <span class="cuadro-label">{t['con.cta.label']}</span>
        <a href={cotizarHref} class="btn-cotizar">{t['con.cta.btn']}</a>
      </div>
    </div>
  </div>
</div>
</section>

<style>
    .contacto-title {
        display: flex;
        color: var(--color-primary);
        justify-self: center;
        font-size: 2.2rem;
        padding-top:5rem;
    }

        .contacto-subtitle {
            display: flex;
            color: var(--color-primary);
            justify-self: center;
            font-size: 1.5rem;
        }
  .contacto-container {
    padding: 2rem;
    padding-bottom: 4rem;
  }

  .parte-inferior {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .formulario {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    height: 100%;
  }

  .formulario input,
  .formulario textarea {
    padding: 0.75rem;
    border: 1px solid var(--color-secondary-light);
    border-radius: 8px;
    font-family: inherit;
    background-color: var(--color-white);
    color: var(--color-primary);
  }

  .formulario input::placeholder,
  .formulario textarea::placeholder {
    color: var(--color-text-light);
  }

  .formulario textarea {
    flex: 1;
    min-height: 120px;
    resize: vertical;
  }

  .formulario button {
    padding: 0.75rem;
    background-color: var(--color-secondary);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.2s;
  }

  .formulario button:hover {
    background-color: var(--color-secondary-hover);
  }

  .cuadros-derecha {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cuadro {
    flex: 1;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }

  .cuadro-label {
    color: var(--color-secondary-light);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
  }

  .cuadro-valor {
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 500;
  }

  .cuadro-cta {
    gap: 1rem;
  }

  .btn-cotizar {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    background-color: var(--color-secondary);
    color: white;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    text-align: center;
    cursor: pointer;
    transition: background-color 0.2s;
    align-self: flex-start;
  }

  .btn-cotizar:hover {
    background-color: var(--color-secondary-hover);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contacto-container {
      padding: 1rem;
      gap: 1.5rem;
    }

    .parte-inferior {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .formulario {
      padding: 1.5rem;
      order: 2;
    }

    .cuadros-derecha {
      flex-direction: row;
      order: 1;
    }

    .cuadro {
      min-height: 100px;
    }
  }

  @media (max-width: 480px) {
    .contacto-container {
      padding: 0.5rem;
      gap: 1rem;
    }

  .contacto-title{
    text-align: center;
    
  }
  .contacto-subtitle {
    font-size:1rem;
    text-align: center;
    
  }

    .texto-flotante {
      padding: 1rem;
    }

    .formulario {
      padding: 1rem;
    }

    .cuadros-derecha {
      flex-direction: column;
    }
  }

  @media (min-width: 1440px) {
    .contacto-title    { font-size: 2.8rem; }
    .contacto-subtitle { font-size: 1.75rem; }

    .contacto-container {
      max-width: 1380px;
      margin: 0 auto;
    }
  }
</style>