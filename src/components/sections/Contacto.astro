---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<section id="contacto" class="contacto-section">
  <div class="contacto-inner">

    <!-- Left: info -->
    <div class="contacto-info" data-aos="fade-right" data-aos-delay="100">
      <h2 class="contacto-title">{t['con.title']}</h2>
      <p class="contacto-subtitle">
        {t['con.subtitle']}<br />{t['con.subtitle2']}
      </p>
      <div class="contacto-details">
        <div class="detail-item">
          <span class="detail-label">Email</span>
          <a href="mailto:gauchino@gauchino.com" class="detail-value">gauchino@gauchino.com</a>
        </div>
        <div class="detail-item">
          <span class="detail-label">{t['con.resp.label']}</span>
          <span class="detail-value">{t['con.resp.value']}</span>
        </div>
      </div>
    </div>

    <!-- Right: form -->
    <form class="formulario" id="formulario-contacto" data-aos="fade-left" data-aos-delay="150">
      <div class="form-row">
        <input type="text" name="name" placeholder={t['con.name']} required />
        <input type="email" name="email" placeholder={t['con.email']} required />
      </div>
      <textarea name="message" placeholder={t['con.message']}></textarea>
      <button type="submit">{t['con.send']}</button>
      <p id="mensaje-exito-contacto">¡Mensaje enviado con éxito!</p>
    </form>

  </div>
</section>

<style>
  .contacto-section {
    padding: 5rem 2rem;
    padding-left: max(2rem, calc((100vw - var(--max-width)) / 2));
    padding-right: max(2rem, calc((100vw - var(--max-width)) / 2));
  }

  .contacto-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius);
    padding: 3.5rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .contacto-inner::before {
    content: '';
    position: absolute;
    bottom: -4rem;
    left: -4rem;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(80px);
    opacity: 0.12;
    pointer-events: none;
  }

  .contacto-title {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .contacto-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.75;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .contacto-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-secondary-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.65;
  }

  .detail-value {
    font-size: 0.92rem;
    color: var(--color-primary);
    font-weight: 500;
    transition: color 0.2s;
  }

  a.detail-value:hover {
    color: var(--color-secondary-light);
  }

  /* Form */
  .formulario {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    position: relative;
    z-index: 1;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }

  .formulario input,
  .formulario textarea {
    padding: 0.85rem 1rem;
    border: 1px solid rgba(45, 27, 90, 0.2);
    border-radius: 12px;
    font-family: inherit;
    font-size: 0.9rem;
    background: rgba(45, 27, 90, 0.06);
    color: var(--color-primary);
    transition: border-color 0.2s ease, background 0.2s ease;
    outline: none;
    width: 100%;
  }

  .formulario input::placeholder,
  .formulario textarea::placeholder {
    color: var(--color-text-light);
  }

  .formulario input:focus,
  .formulario textarea:focus {
    border-color: rgba(70, 1, 250, 0.5);
    background: rgba(70, 1, 250, 0.05);
  }

  .formulario textarea {
    min-height: 130px;
    resize: vertical;
  }

  .formulario button {
    padding: 0.9rem;
    background-color: var(--color-secondary);
    color: #fff;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    font-family: inherit;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 0 20px rgba(70, 1, 250, 0.35);
  }

  .formulario button:hover {
    background-color: var(--color-secondary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 28px rgba(70, 1, 250, 0.55);
  }

  #mensaje-exito-contacto {
    display: none;
    color: var(--color-secondary-light);
    font-weight: 500;
    font-size: 0.9rem;
    text-align: center;
  }

  @media (max-width: 900px) {
    .contacto-inner {
      grid-template-columns: 1fr;
      padding: 2.5rem 2rem;
      gap: 2rem;
    }
  }

  @media (max-width: 600px) {
    .contacto-section {
      padding: 3rem 1rem;
    }
    .contacto-inner {
      padding: 1.75rem 1.25rem;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
    .contacto-title {
      font-size: 1.6rem;
    }
  }

  @media (min-width: 1440px) {
    .contacto-title    { font-size: 2.2rem; }
    .contacto-subtitle { font-size: 1rem; }
  }
</style>

<script is:inline defer>
  const formContacto = document.getElementById("formulario-contacto");
  const mensajeContacto = document.getElementById("mensaje-exito-contacto");

  formContacto.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(formContacto);
    const response = await fetch("https://formspree.io/f/xnjgodwe", {
      method: "POST",
      body: data,
      headers: { Accept: "application/json" },
    });
    if (response.ok) {
      mensajeContacto.style.display = "block";
      formContacto.reset();
      setTimeout(() => { mensajeContacto.style.display = "none"; }, 3500);
    }
  });
</script>
