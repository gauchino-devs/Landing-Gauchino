---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<div id="clientes">

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="stats-grid">
      <div class="stat-item" data-aos="fade-up" data-aos-delay="0">
        <span class="stat-num">150%</span>
        <span class="stat-label">{t['cli.stat1.label']}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-aos="fade-up" data-aos-delay="100">
        <span class="stat-num">100%</span>
        <span class="stat-label">{t['cli.stat2.label']}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-aos="fade-up" data-aos-delay="200">
        <span class="stat-num">100%</span>
        <span class="stat-label">{t['cli.stat3.label']}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-aos="fade-up" data-aos-delay="300">
        <span class="stat-num">100%</span>
        <span class="stat-label">{t['cli.stat4.label']}</span>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials-section">
    <div class="testimonials-grid">
      <div class="testimonial-card" data-aos="fade-up" data-aos-delay="100">
        <div class="quote-mark">&ldquo;</div>
        <p class="review-text">{t['cli.review1.text']}</p>
        <div class="review-footer">
          <div class="avatar">K</div>
          <p class="review-author">{t['cli.review1.author']}</p>
        </div>
      </div>

      <div class="testimonial-card" data-aos="fade-up" data-aos-delay="200">
        <div class="quote-mark">&ldquo;</div>
        <p class="review-text">{t['cli.review2.text']}</p>
        <div class="review-footer">
          <div class="avatar">M</div>
          <p class="review-author">{t['cli.review2.author']}</p>
        </div>
      </div>

      <div class="cta-card" data-aos="fade-up" data-aos-delay="300">
        <p class="cta-titulo">{t['cli.cta.title']}</p>
        <a href="#contacto" class="cta-btn">{t['cli.cta.btn']}</a>
      </div>
    </div>
  </section>

</div>

<style>
  /* ─── Stats ─── */
  .stats-section {
    padding: 4.5rem 2rem;
    background: linear-gradient(145deg, #1a0e3c 0%, #2D1B5A 45%, #1c1040 100%);
    position: relative;
    overflow: hidden;
  }

  .stats-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 15% 50%, rgba(70, 1, 250, 0.18) 0%, transparent 45%),
      radial-gradient(circle at 85% 50%, rgba(70, 1, 250, 0.12) 0%, transparent 45%);
    pointer-events: none;
  }

  .stats-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.5rem 1rem;
    text-align: center;
  }

  .stat-num {
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stat-divider {
    width: 1px;
    height: 70px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  /* ─── Testimonials ─── */
  .testimonials-section {
    padding: 3rem 2rem 4.5rem;
    padding-left: max(2rem, calc((100vw - var(--max-width)) / 2));
    padding-right: max(2rem, calc((100vw - var(--max-width)) / 2));
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.25rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonial-card {
    background: var(--color-primary-light);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
    border-color: rgba(70, 1, 250, 0.3);
  }

  .quote-mark {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-secondary-light);
    line-height: 0.7;
    font-family: Georgia, 'Times New Roman', serif;
    opacity: 0.55;
    user-select: none;
  }

  .review-text {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.93rem;
    line-height: 1.7;
    flex: 1;
  }

  .review-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin-top: auto;
  }

  .avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-secondary) 0%, #8b5cf6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 0 10px rgba(70, 1, 250, 0.4);
  }

  .review-author {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-secondary-light);
    line-height: 1.2;
  }

  /* ─── CTA Card ─── */
  .cta-card {
    background: linear-gradient(145deg, var(--color-primary) 0%, #3a1a7e 100%);
    border: 1px solid rgba(70, 1, 250, 0.35);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .cta-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(70, 1, 250, 0.2);
  }

  .cta-card::after {
    content: '';
    position: absolute;
    top: -3rem;
    right: -3rem;
    width: 14rem;
    height: 14rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(65px);
    opacity: 0.3;
    pointer-events: none;
  }

  .cta-titulo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    position: relative;
    z-index: 1;
  }

  .cta-btn {
    display: inline-block;
    align-self: flex-start;
    padding: 0.65rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    background-color: var(--color-secondary);
    color: #fff;
    box-shadow: 0 0 18px rgba(70, 1, 250, 0.45);
    transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    position: relative;
    z-index: 1;
    white-space: nowrap;
  }

  .cta-btn:hover {
    background-color: #6117ff;
    box-shadow: 0 0 26px rgba(97, 23, 255, 0.6);
    transform: translateY(-2px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    .stat-divider {
      display: none;
    }
    .testimonials-grid {
      grid-template-columns: 1fr 1fr;
    }
    .cta-card {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .stats-section {
      padding: 3rem 1.5rem;
    }
    .testimonials-section {
      padding: 2rem 1rem 3rem;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
    .cta-card {
      grid-column: span 1;
    }
  }

  @media (min-width: 1440px) {
    .stat-num { font-size: 5.5rem; }
    .stat-label { font-size: 0.95rem; }
  }
</style>
