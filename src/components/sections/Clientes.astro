---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<div class="clientes-container" id="clientes">
  <!-- Parte Superior -->
  <div class="parte-superior">
    <div class="bloque-texto" data-aos="fade-right" data-aos-duration="700">
      <h2 class="clientes-title">{t['cli.title1']} <span class="highlight">{t['cli.title2']}</span></h2>
      <p class="bloque-parrafo">{t['cli.desc']}</p>
    </div>
    <div class="cuadro-grande" data-aos="fade-left" data-aos-duration="700" data-aos-delay="150">
      <div class="celda"><span class="celda-num">100%</span><span class="celda-sep"></span><span class="celda-label">{t['cli.stat1.label']}</span></div>
      <div class="celda"><span class="celda-num">100%</span><span class="celda-sep"></span><span class="celda-label">{t['cli.stat2.label']}</span></div>
      <div class="celda"><span class="celda-num">100%</span><span class="celda-sep"></span><span class="celda-label">{t['cli.stat3.label']}</span></div>
      <div class="celda"><span class="celda-num">100%</span><span class="celda-sep"></span><span class="celda-label">{t['cli.stat4.label']}</span></div>
    </div>
  </div>
  
  <!-- Parte Inferior -->
  <h3 class="inferior-titulo" data-aos="fade-up">{t['cli.reviews.heading']}</h3>
  <div class="parte-inferior">
    <div class="resena-1" data-aos="fade-up" data-aos-delay="100">
      <p class="resena-autor">{t['cli.review1.author']}</p>
      <span class="resena-sep"></span>
      <p class="resena-texto">{t['cli.review1.text']}</p>
    </div>
    <div class="resena-2" data-aos="fade-up" data-aos-delay="200">
      <p class="resena-autor">{t['cli.review2.author']}</p>
      <span class="resena-sep"></span>
      <p class="resena-texto">{t['cli.review2.text']}</p>
    </div>
    <div class="cta" data-aos="fade-up" data-aos-delay="300">
      <p class="cta-titulo">{t['cli.cta.title']}</p>
      <a href="#contacto" class="cta-btn">{t['cli.cta.btn']}</a>
    </div>
  </div>
</div>

<style>
  .clientes-title {
    color: var(--color-primary);
    font-size: 2.2rem;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .highlight {
    color: var(--color-secondary);
  }

  .bloque-parrafo {
    color: var(--color-primary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .clientes-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    padding: 1rem;
    gap: 1rem;
  }

  .parte-superior {
    flex: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .bloque-texto {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
  }

  .cuadro-grande {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    
  }

  .celda {
    background-color: var(--color-primary);
    display: flex;
    border-radius: var(--radius);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.2rem;
    border: 1px solid rgba(70, 1, 250, 0.15);
    position: relative;
    overflow: hidden;
  }

  .celda::after {
    content: '';
    position: absolute;
    top: 2rem;
    right: 2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .celda-num {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-secondary-light);
    line-height: 1;
  }

  .celda-label {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: 0.03em;
  }

  .parte-inferior {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .resena-1,
  .resena-2 {
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .resena-autor {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-secondary-light);
    letter-spacing: 0.04em;
  }

  .resena-sep {
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--color-secondary);
    border-radius: 999px;
  }

  .resena-texto {
    font-size: 0.97rem;
    line-height: 1.65;
    color: var(--color-white);
  }

  .inferior-titulo {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: 0 0.25rem;
  }

  .cta {
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
  }

  .cta-titulo {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.35;
  }

  .cta-btn {
    display: inline-block;
    align-self: flex-start;
    padding: 0.65rem 1.5rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    background-color: var(--color-secondary);
    color: var(--color-white);
    backdrop-filter: blur(8px);
    box-shadow: 0 0 18px 4px rgba(204, 175, 255, 0.45);
    transition: box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .cta-btn:hover {
    background-color: #6117ff;
    box-shadow: 0 0 15px 3px rgba(174, 127, 254, 0.6);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .clientes-container {
      padding: 1rem;
      gap: 1rem;
      height: auto;
    }

    .parte-superior {
      grid-template-columns: 1fr;
    }

    .bloque-texto {
      order: 1;
      padding: 1.5rem;
    }

    .cuadro-grande {
      order: 2;
      min-height: 250px;
    }

    .parte-inferior {
      grid-template-columns: 1fr;
    }

    .resena-1 {
      order: 3;
    }

    .resena-2 {
      order: 4;
    }

    .cta {
      order: 5;
    }
  }

  @media (max-width: 480px) {
    .clientes-container {
      padding: 0.5rem;
    }

    .bloque-texto {
      padding: 1rem;
    }

    .resena-1,
    .resena-2,
    .cta {
      padding: 1rem;
    }
  }

  @media (min-width: 1440px) {
    .clientes-container {
      max-width: 1380px;
      margin: 0 auto;
    }

    .clientes-title { font-size: 2.8rem; }
    .bloque-parrafo { font-size: 1.1rem; }
    .celda-num      { font-size: 3.2rem; }
    .celda-label    { font-size: 1.75rem; }
    .inferior-titulo { font-size: 1.4rem; }
    .resena-autor   { font-size: 1.1rem; }
    .resena-texto   { font-size: 1.05rem; }
    .cta-titulo     { font-size: 1.3rem; }
  }
</style>