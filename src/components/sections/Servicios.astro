---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<section id="servicios" class="servicios-section">
  <h2 class="servicios-title" data-aos="fade-up">{t['serv.heading']}</h2>
  <div class="servicios-grid">

    <!-- Left: Big card -->
    <div class="box-grande" data-aos="fade-right" data-aos-delay="100">
      <div class="icon-wrapper">
        <img src="/codigo.png" alt="Desarrollo" class="service-icon" />
      </div>
      <h3 class="box-grande-titulo">{t['serv.dev.title']}</h3>
      <p class="box-grande-desc">{t['serv.dev.desc']}</p>
    </div>

    <!-- Right: 3x2 grid of 6 cards -->
    <div class="servicios-right">
      <div class="box-small" data-aos="fade-up" data-aos-delay="150">
        <div class="icon-wrapper">
          <img src="/integracion.png" alt="Integración" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.int.title']}</h3>
        <p class="box-small-desc">{t['serv.int.desc']}</p>
      </div>
      <div class="box-small" data-aos="fade-up" data-aos-delay="200">
        <div class="icon-wrapper">
          <img src="/mobile.png" alt="Mobile" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.mob.title']}</h3>
        <p class="box-small-desc">{t['serv.mob.desc']}</p>
      </div>
      <div class="box-small" data-aos="fade-up" data-aos-delay="250">
        <div class="icon-wrapper">
          <img src="/bot.png" alt="Automatización" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.aut.title']}</h3>
        <p class="box-small-desc">{t['serv.aut.desc']}</p>
      </div>
      <div class="box-small" data-aos="fade-up" data-aos-delay="300">
        <div class="icon-wrapper">
          <img src="/erp.png" alt="ERP" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.erp.title']}</h3>
        <p class="box-small-desc">{t['serv.erp.desc']}</p>
      </div>
      <div class="box-small" data-aos="fade-up" data-aos-delay="350">
        <div class="icon-wrapper">
          <img src="/sitio-web.png" alt="Diseño Web" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.web.title']}</h3>
        <p class="box-small-desc">{t['serv.web.desc']}</p>
      </div>
      <div class="box-small" data-aos="fade-up" data-aos-delay="400">
        <div class="icon-wrapper">
          <img src="/soporte.png" alt="Soporte" class="service-icon" />
        </div>
        <h3 class="box-small-titulo">{t['serv.sup.title']}</h3>
        <p class="box-small-desc">{t['serv.sup.desc']}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .servicios-section {
    padding: 1.5rem 2rem 4rem;
    padding-left: max(2rem, calc((100vw - var(--max-width)) / 2));
    padding-right: max(2rem, calc((100vw - var(--max-width)) / 2));
    background: transparent;
  }

  .servicios-title {
    color: #fff;
    font-size: 2.2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 2rem;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 1rem;
    min-height: 72vh;
  }

  .icon-wrapper {
    width: 3rem;
    height: 3rem;
    background-color: var(--color-secondary);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem;
    flex-shrink: 0;
    box-shadow: 0 0 14px rgba(70, 1, 250, 0.5);
  }

  .service-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  /* Big card */
  .box-grande {
    border: 1.5px solid rgba(70, 1, 250, 0.45);
    background: linear-gradient(145deg, var(--color-primary) 0%, #221447 100%);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(70, 1, 250, 0.15), inset 0 0 40px rgba(70, 1, 250, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    height: 100%;
  }

  .box-grande:hover {
    box-shadow: 0 0 60px rgba(70, 1, 250, 0.28), inset 0 0 40px rgba(70, 1, 250, 0.1);
    transform: translateY(-2px);
  }

  .box-grande::after {
    content: '';
    position: absolute;
    top: -4rem;
    right: -4rem;
    width: 16rem;
    height: 16rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(70px);
    opacity: 0.35;
    pointer-events: none;
  }

  .box-grande-titulo {
    color: #fff;
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    line-height: 1.2;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }

  .box-grande-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  /* Right grid */
  .servicios-right {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 1rem;
  }

  .box-small {
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: var(--color-primary-light);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .box-small:hover {
    border-color: rgba(70, 1, 250, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.25), 0 0 20px rgba(70, 1, 250, 0.12);
  }

  .box-small::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.3;
    pointer-events: none;
  }

  .box-small-titulo {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .box-small-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .servicios-grid {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .servicios-right {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 1fr);
    }

    .box-grande {
      min-height: 280px;
    }
  }

  @media (max-width: 600px) {
    .servicios-section {
      padding: 3rem 1rem;
    }

    .servicios-right {
      grid-template-columns: 1fr 1fr;
      overflow-x: visible;
    }

    .servicios-title {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 440px) {
    .servicios-right {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1440px) {
    .servicios-title {
      font-size: 2.8rem;
      margin-bottom: 2.5rem;
    }
    .box-grande-titulo { font-size: 2.2rem; }
    .box-grande-desc   { font-size: 1.05rem; }
    .box-small-titulo  { font-size: 1.2rem; }
    .box-small-desc    { font-size: 0.9rem; }
  }
</style>
