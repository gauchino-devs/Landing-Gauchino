---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<section id="servicios">
<h2 class="servicios-title" data-aos="fade-up">{t['serv.heading']}</h2>
<div class="servicios-container">

  <!-- Lado Izquierdo -->
  <div class="left-side">
    <div class="box-grande" data-aos="fade-right" data-aos-delay="100">
      <div class="icon-wrapper">
        <img src="/codigo.png" alt="Desarrollo" class="service-icon" />
      </div>
      <h3 class="box-grande-titulo">{t['serv.dev.title']}</h3>
      <p class="box-grande-desc">{t['serv.dev.desc']}</p>
    </div>
    <div class="boxes-chicos">
      <div class="box-chico" data-aos="fade-up" data-aos-delay="200">
        <div class="icon-wrapper">
          <img src="/erp.png" alt="ERP" class="service-icon" />
        </div>
        <h3 class="box-chico-titulo">{t['serv.erp.title']}</h3>
        <p class="box-chico-desc">{t['serv.erp.desc']}</p>
      </div>
      <div class="box-chico" data-aos="fade-up" data-aos-delay="300">
        <div class="icon-wrapper">
          <img src="/sitio-web.png" alt="Sitio Web" class="service-icon" />
        </div>
        <h3 class="box-chico-titulo">{t['serv.web.title']}</h3>
        <p class="box-chico-desc">{t['serv.web.desc']}</p>
      </div>
    </div>
  </div>

  <!-- Lado Derecho -->
  <div class="right-side">
    <div class="boxes-arriba">
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="150">
        <div class="icon-wrapper">
          <img src="/integracion.png" alt="Integración" class="service-icon" />
        </div>
        <h3 class="box-derecho-titulo">{t['serv.int.title']}</h3>
        <p class="box-derecho-desc">{t['serv.int.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="200">
        <div class="icon-wrapper">
          <img src="/mobile.png" alt="Mobile" class="service-icon" />
        </div>
        <h3 class="box-derecho-titulo">{t['serv.mob.title']}</h3>
        <p class="box-derecho-desc">{t['serv.mob.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="250">
        <div class="icon-wrapper">
          <img src="/bot.png" alt="IA" class="service-icon" />
        </div>
        <h3 class="box-derecho-titulo">{t['serv.ai.title']}</h3>
        <p class="box-derecho-desc">{t['serv.ai.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="300">
        <div class="icon-wrapper">
          <img src="/automatizacion.png" alt="Automatización" class="service-icon" />
        </div>
        <h3 class="box-derecho-titulo">{t['serv.aut.title']}</h3>
        <p class="box-derecho-desc">{t['serv.aut.desc']}</p>
      </div>
    </div>
    <div class="box-abajo" data-aos="fade-left" data-aos-delay="350">
      <div class="icon-wrapper">
        <img src="/soporte.png" alt="Soporte" class="service-icon" />
      </div>
      <h3 class="box-abajo-titulo">{t['serv.sup.title']}</h3>
      <p class="box-abajo-desc">{t['serv.sup.desc']}</p>
    </div>
  </div>
</div>
</section>

<style>
    .servicios-title{
        display: flex;
        color: var(--color-primary);
        justify-self: center;
        font-size: 2.2rem;
    }
  .servicios-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    height: 100vh;
    padding: 1rem;
  }

  .left-side {
    display: grid;
    grid-template-rows: 3fr 1fr;
    gap: 1rem;
    height: 100%;
  }

  .icon-wrapper {
    width: 3rem;
    height: 3rem;
    background-color: var(--color-secondary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    flex-shrink: 0;
  }

  .service-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .box-grande {
    border: 2px solid #333;
    background-color: var(--color-primary);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
  }

  .box-grande::after {
    content: '';
    position: absolute;
    top: -3rem;
    right: -3rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(60px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-grande-titulo {
    color: var(--color-white);
    font-size: 1.8rem;
    line-height: 1.2;
  }

  .box-grande-desc {
    color: var(--color-white);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  .boxes-chicos {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .box-chico {
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-chico::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-chico-titulo {
    color: var(--color-white);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .box-chico-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .right-side {
    display: grid;
    grid-template-rows: 3fr 1fr;
    gap: 1rem;
    height: 100%;
  }

  .boxes-arriba {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
  }

  .box-derecho {
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-derecho::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-derecho-titulo {
    color: var(--color-white);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .box-derecho-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .box-abajo {
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-abajo::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-abajo-titulo {
    color: var(--color-white);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .box-abajo-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .servicios-title {
      font-size: 1.8rem;
      display: flex;
      justify-content: center;
      padding: 0 1rem;
    }

    .servicios-container {
      grid-template-columns: unset;
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: visible;
      height: auto;
      padding: 0.5rem 1rem 1.5rem;
      gap: 0.75rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .servicios-container::-webkit-scrollbar {
      display: none;
    }

    /* Aplanar contenedores intermedios para que las cards queden al mismo nivel */
    .left-side,
    .right-side,
    .boxes-chicos,
    .boxes-arriba {
      display: contents;
    }

    .box-grande,
    .box-chico,
    .box-derecho,
    .box-abajo {
      flex: 0 0 78vw;
      min-height: 260px;
      scroll-snap-align: start;
      order: unset;
    }

    .box-grande-desc {
      display: none;
    }
  }

  @media (min-width: 1440px) {
    .servicios-title {
      font-size: 2.8rem;
      margin-bottom: 0.5rem;
    }

    .servicios-container {
      max-width: 1380px;
      margin: 0 auto;
    }

    .box-grande-titulo { font-size: 2.2rem; }
    .box-grande-desc   { font-size: 1.1rem; }
    .box-chico-titulo  { font-size: 1.4rem; }
    .box-chico-desc    { font-size: 0.95rem; }
    .box-derecho-titulo { font-size: 1.4rem; }
    .box-derecho-desc  { font-size: 0.95rem; }
    .box-abajo-titulo  { font-size: 1.4rem; }
    .box-abajo-desc    { font-size: 0.95rem; }
  }
</style>