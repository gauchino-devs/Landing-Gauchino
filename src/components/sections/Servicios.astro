---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<section id="servicios" class="servicios-section">
  <!-- Flash overlay for the warp moment -->
  <div class="portal-flash-overlay"></div>

  <div class="servicios-content">
    <h2 class="servicios-title">{t['serv.heading']}</h2>
    <div class="servicios-grid">

      <!-- Left: Big card -->
      <div class="box-grande service-card">
        <div class="icon-wrapper">
          <img src="/codigo.png" alt="Desarrollo" class="service-icon" />
        </div>
        <h3 class="box-grande-titulo">{t['serv.dev.title']}</h3>
        <p class="box-grande-desc">{t['serv.dev.desc']}</p>
      </div>

      <!-- Right: 3x2 grid of 6 cards -->
      <div class="servicios-right">
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/integracion.png" alt="Integración" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.int.title']}</h3>
          <p class="box-small-desc">{t['serv.int.desc']}</p>
        </div>
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/mobile.png" alt="Mobile" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.mob.title']}</h3>
          <p class="box-small-desc">{t['serv.mob.desc']}</p>
        </div>
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/bot.png" alt="Automatización" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.aut.title']}</h3>
          <p class="box-small-desc">{t['serv.aut.desc']}</p>
        </div>
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/erp.png" alt="ERP" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.erp.title']}</h3>
          <p class="box-small-desc">{t['serv.erp.desc']}</p>
        </div>
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/sitio-web.png" alt="Diseño Web" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.web.title']}</h3>
          <p class="box-small-desc">{t['serv.web.desc']}</p>
        </div>
        <div class="box-small service-card">
          <div class="icon-wrapper">
            <img src="/soporte.png" alt="Soporte" class="service-icon" />
          </div>
          <h3 class="box-small-titulo">{t['serv.sup.title']}</h3>
          <p class="box-small-desc">{t['serv.sup.desc']}</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import * as THREE from 'three';

  gsap.registerPlugin(ScrollTrigger);

  function initPortalDive() {
    const section = document.getElementById('servicios');
    if (!section || section.dataset.portalInit) return;
    section.dataset.portalInit = '1';

    const title = section.querySelector<HTMLElement>('.servicios-title');
    const cards = section.querySelectorAll<HTMLElement>('.service-card');
    const flashOverlay = section.querySelector<HTMLElement>('.portal-flash-overlay');
    if (!flashOverlay || cards.length === 0) return;

    const isMobile = window.matchMedia('(max-width: 767px)').matches;

    /* ── Mobile: simplified fade + slide ── */
    if (isMobile) {
      gsap.set(cards, { visibility: 'hidden', opacity: 0, y: 60 });
      if (title) gsap.set(title, { visibility: 'hidden', opacity: 0, y: 30 });

      const mobileTl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 60%',
          end: '+=150%',
          pin: true,
          scrub: 2,
        },
      });

      // Background lightens
      mobileTl.to(section, { backgroundColor: '#1a0a2e', duration: 0.3 }, 0);
      // Title appears
      if (title) {
        mobileTl.to(title, { visibility: 'visible', opacity: 1, y: 0, duration: 0.15 }, 0.15);
      }
      // Cards stagger in
      mobileTl.to(cards, {
        visibility: 'visible',
        opacity: 1,
        y: 0,
        duration: 0.08,
        stagger: 0.03,
        ease: 'back.out(1.4)',
      }, 0.30);

      return;
    }

    /* ── Desktop: Full Portal Dive ── */

    // 0. Hide all content initially — pure dark void
    gsap.set(cards, { visibility: 'hidden', opacity: 0, scale: 0, y: 40 });
    if (title) gsap.set(title, { visibility: 'hidden', opacity: 0 });
    gsap.set(flashOverlay, { opacity: 0 });

    // 1. Create Three.js canvas — appended to body as fixed overlay
    const vw = window.innerWidth;
    const vh = window.innerHeight;

    const canvasContainer = document.createElement('div');
    canvasContainer.className = 'portal-canvas-fixed';
    canvasContainer.style.cssText =
      'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:100;will-change:transform,opacity;display:none;';
    document.body.appendChild(canvasContainer);

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(vw, vh);
    canvasContainer.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, vw / vh, 1, 1000);
    camera.position.z = 300;

    // 2. Particle system — start at screen edges, converge to center
    const PARTICLE_COUNT = 800;
    const positions = new Float32Array(PARTICLE_COUNT * 3);
    const colors = new Float32Array(PARTICLE_COUNT * 3);
    const radii = new Float32Array(PARTICLE_COUNT);     // orbital radius (world units)
    const angles = new Float32Array(PARTICLE_COUNT);
    const speeds = new Float32Array(PARTICLE_COUNT);     // base orbit speed
    const startRadii = new Float32Array(PARTICLE_COUNT); // large initial spread

    const purple = new THREE.Color(0x8b5cf6);
    const white = new THREE.Color(0xffffff);

    // Convert screen-edge pixel distances to world units (approx)
    const worldScale = 0.55; // rough px→world at z=300, fov=60
    const maxSpread = Math.max(vw, vh) * worldScale;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      angles[i] = Math.random() * Math.PI * 2;
      speeds[i] = 0.4 + Math.random() * 1.8;

      // Final orbital radius (tight vortex)
      radii[i] = 6 + Math.random() * 75;
      // Start radius — spread across screen edges
      startRadii[i] = maxSpread * (0.5 + Math.random() * 0.5);

      // Initial positions at outer spread
      positions[i * 3]     = Math.cos(angles[i]) * startRadii[i];
      positions[i * 3 + 1] = Math.sin(angles[i]) * startRadii[i];
      positions[i * 3 + 2] = -Math.random() * 80;

      const c = Math.random() < 0.6 ? purple : white;
      colors[i * 3]     = c.r;
      colors[i * 3 + 1] = c.g;
      colors[i * 3 + 2] = c.b;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

    const material = new THREE.PointsMaterial({
      size: 4,
      sizeAttenuation: true,
      vertexColors: true,
      transparent: true,
      opacity: 0.9,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const points = new THREE.Points(geometry, material);
    scene.add(points);

    // Convergence progress: 0 = fully spread, 1 = tight vortex
    let convergence = 0;
    let orbitSpeedMultiplier = 1;

    let animFrameId: number | null = null;
    let lastTime = performance.now();
    let rendererAlive = true;

    function animateParticles() {
      if (!rendererAlive) return;
      const now = performance.now();
      const dt = Math.min((now - lastTime) / 1000, 0.05); // cap delta
      lastTime = now;

      const posArr = (geometry.getAttribute('position') as THREE.BufferAttribute).array as Float32Array;
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        angles[i] += speeds[i] * orbitSpeedMultiplier * dt;
        // Lerp radius from startRadii → radii based on convergence
        const currentR = startRadii[i] + (radii[i] - startRadii[i]) * convergence;
        posArr[i * 3]     = Math.cos(angles[i]) * currentR;
        posArr[i * 3 + 1] = Math.sin(angles[i]) * currentR;
      }
      (geometry.getAttribute('position') as THREE.BufferAttribute).needsUpdate = true;
      renderer.render(scene, camera);
      animFrameId = requestAnimationFrame(animateParticles);
    }

    // 3. GSAP ScrollTrigger timeline
    gsap.set(canvasContainer, { scale: 0, opacity: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=250%',
        pin: true,
        scrub: 2,
        anticipatePin: 1,
        onEnter: () => {
          // Show and start rendering the canvas
          canvasContainer.style.display = 'block';
          if (!animFrameId) animateParticles();
        },
        onLeaveBack: () => {
          canvasContainer.style.display = 'none';
        },
      },
    });

    /* ── Phase 1 (0 → 0.25): Dark void + portal birth ── */
    // First 10% — pure dark, nothing happens (the "pause")
    // 10% → 25% — portal scale 0→1, particles converge from edges to vortex
    tl.to(canvasContainer, { scale: 1, opacity: 1, duration: 0.15, ease: 'power2.out' }, 0.10);
    // Animate convergence via an object target
    const convTarget = { value: 0 };
    tl.to(convTarget, {
      value: 1,
      duration: 0.15,
      ease: 'power2.out',
      onUpdate: () => { convergence = convTarget.value; },
    }, 0.10);

    /* ── Phase 2 (0.25 → 0.60): The Dive ── */
    // Speed up vortex spin
    const speedTarget = { value: 1 };
    tl.to(speedTarget, {
      value: 4,
      duration: 0.35,
      ease: 'power2.in',
      onUpdate: () => { orbitSpeedMultiplier = speedTarget.value; },
    }, 0.25);
    // Portal expands massively and fades
    tl.to(canvasContainer, { scale: 12, opacity: 0, duration: 0.35, ease: 'power3.in' }, 0.25);
    // Background transitions from #0d0520 → #1a0a2e
    tl.to(section, { backgroundColor: '#1a0a2e', duration: 0.35 }, 0.25);
    // Warp flash — radial gradient pulse at midpoint (~0.42)
    tl.to(flashOverlay, { opacity: 0.6, duration: 0.06 }, 0.39);
    tl.to(flashOverlay, { opacity: 0, duration: 0.08 }, 0.45);

    /* ── Phase 3 (0.60 → 1.00): Cards emerge from the void ── */
    // Hide canvas completely
    tl.set(canvasContainer, { display: 'none' }, 0.60);

    // Title fades in first
    if (title) {
      tl.to(title, { visibility: 'visible', opacity: 1, duration: 0.08 }, 0.60);
    }

    // Big card (index 0) appears first, then the 6 small cards
    const cardOrder = [0, 1, 2, 3, 4, 5, 6];
    cardOrder.forEach((idx, order) => {
      const card = cards[idx];
      if (!card) return;
      const start = 0.65 + order * 0.025;
      tl.to(card, {
        visibility: 'visible',
        opacity: 1,
        scale: 1,
        y: 0,
        duration: 0.08,
        ease: 'back.out(1.9)',
        immediateRender: false,
      }, start);
      // Glow pulse on arrival
      const arriveAt = start + 0.08;
      tl.to(card, {
        boxShadow: '0 0 40px rgba(139, 92, 246, 0.9)',
        duration: 0.02,
      }, arriveAt);
      tl.to(card, {
        boxShadow: '0 0 40px rgba(70, 1, 250, 0.15), inset 0 0 40px rgba(70, 1, 250, 0.06)',
        duration: 0.04,
      }, arriveAt + 0.02);
    });

    // Pin released — at progress 1.0 the section unpins and page scrolls on

    // Restore hover transitions when pin is left
    tl.scrollTrigger!.vars.onLeave = () => {
      cards.forEach((c) => gsap.set(c, { clearProps: 'transform,opacity,boxShadow,x,y,scale,visibility' }));
      if (title) gsap.set(title, { clearProps: 'all' });
      canvasContainer.style.display = 'none';
    };

    // 4. Resize handler
    function onResize() {
      if (!rendererAlive) return;
      const w = window.innerWidth;
      const h = window.innerHeight;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', onResize);

    // 5. Cleanup
    function cleanup() {
      rendererAlive = false;
      if (animFrameId !== null) cancelAnimationFrame(animFrameId);
      renderer.dispose();
      renderer.forceContextLoss();
      canvasContainer.remove();
      geometry.dispose();
      material.dispose();
      window.removeEventListener('resize', onResize);
      ScrollTrigger.getAll().forEach((st) => {
        if (st.trigger === section) st.kill();
      });
      delete section.dataset.portalInit;
    }
    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }

  initPortalDive();
  document.addEventListener('astro:page-load', initPortalDive);
</script>

<style>
  .servicios-section {
    position: relative;
    min-height: 100vh;
    background: #0d0520;
    overflow: hidden;
    /* Use viewport-aware padding so pinned state has no gaps */
    padding: 4vh 2rem 4vh;
    padding-left: max(2rem, calc((100vw - var(--max-width)) / 2));
    padding-right: max(2rem, calc((100vw - var(--max-width)) / 2));
  }

  .portal-flash-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(139, 92, 246, 0.5) 0%, rgba(255, 255, 255, 0.4) 40%, transparent 70%);
    pointer-events: none;
    z-index: 20;
    opacity: 0;
  }

  .servicios-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    min-height: 80vh;
  }

  .servicios-title {
    color: #fff;
    font-size: 2.2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
    z-index: 2;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 1rem;
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .icon-wrapper {
    width: 3rem;
    height: 3rem;
    background-color: var(--color-secondary);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem;
    flex-shrink: 0;
    box-shadow: 0 0 14px rgba(70, 1, 250, 0.5);
  }

  .service-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  /* Big card */
  .box-grande {
    border: 1.5px solid var(--color-border);
    background: linear-gradient(145deg, var(--color-white) 0%, rgba(230,232,255,0.88) 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(70, 1, 250, 0.15), inset 0 0 40px rgba(70, 1, 250, 0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    height: 100%;
  }

  .box-grande:hover {
    box-shadow: 0 0 60px rgba(70, 1, 250, 0.28), inset 0 0 40px rgba(70, 1, 250, 0.1);
    transform: translateY(-2px);
  }

  .box-grande::after {
    content: '';
    position: absolute;
    top: -4rem;
    right: -4rem;
    width: 16rem;
    height: 16rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(70px);
    opacity: 0.35;
    pointer-events: none;
  }

  .box-grande-titulo {
    color: var(--color-primary);
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    line-height: 1.2;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }

  .box-grande-desc {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  /* Right grid */
  .servicios-right {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 1rem;
  }

  .box-small {
    border: 1px solid var(--color-border);
    background: var(--color-white);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .box-small:hover {
    border-color: rgba(70, 1, 250, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.25), 0 0 20px rgba(70, 1, 250, 0.12);
  }

  .box-small::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.3;
    pointer-events: none;
  }

  .box-small-titulo {
    color: var(--color-primary);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .box-small-desc {
    color: var(--color-text-light);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .servicios-grid {
      grid-template-columns: 1fr;
    }

    .servicios-right {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 1fr);
    }

    .box-grande {
      min-height: 280px;
    }
  }

  @media (max-width: 600px) {
    .servicios-section {
      padding: 3rem 1rem;
    }

    .servicios-right {
      grid-template-columns: 1fr 1fr;
      overflow-x: visible;
    }

    .servicios-title {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 440px) {
    .servicios-right {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1440px) {
    .servicios-title {
      font-size: 2.8rem;
      margin-bottom: 2.5rem;
    }
    .box-grande-titulo { font-size: 2.2rem; }
    .box-grande-desc   { font-size: 1.05rem; }
    .box-small-titulo  { font-size: 1.2rem; }
    .box-small-desc    { font-size: 0.9rem; }
  }
</style>
