---
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale ?? 'es');
---
<section id="servicios">
<h2 class="servicios-title" data-aos="fade-up">{t['serv.heading']}</h2>
<div class="servicios-container">

  <!-- Lado Izquierdo -->
  <div class="left-side">
    <div class="box-grande" data-aos="fade-right" data-aos-delay="100">
      <h3 class="box-grande-titulo">{t['serv.dev.title']}</h3>
      <p class="box-grande-desc">{t['serv.dev.desc']}</p>
    </div>
    <div class="boxes-chicos">
      <div class="box-chico" data-aos="fade-up" data-aos-delay="200">
        <h3 class="box-chico-titulo">{t['serv.erp.title']}</h3>
        <p class="box-chico-desc">{t['serv.erp.desc']}</p>
      </div>
      <div class="box-chico" data-aos="fade-up" data-aos-delay="300">
        <h3 class="box-chico-titulo">{t['serv.web.title']}</h3>
        <p class="box-chico-desc">{t['serv.web.desc']}</p>
      </div>
    </div>
  </div>
  
  <!-- Lado Derecho -->
  <div class="right-side">
    <div class="boxes-arriba">
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="150">
        <h3 class="box-derecho-titulo">{t['serv.int.title']}</h3>
        <p class="box-derecho-desc">{t['serv.int.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="200">
        <h3 class="box-derecho-titulo">{t['serv.mob.title']}</h3>
        <p class="box-derecho-desc">{t['serv.mob.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="250">
        <h3 class="box-derecho-titulo">{t['serv.ai.title']}</h3>
        <p class="box-derecho-desc">{t['serv.ai.desc']}</p>
      </div>
      <div class="box-derecho" data-aos="fade-up" data-aos-delay="300">
        <h3 class="box-derecho-titulo">{t['serv.aut.title']}</h3>
        <p class="box-derecho-desc">{t['serv.aut.desc']}</p>
      </div>
    </div>
    <div class="box-abajo" data-aos="fade-left" data-aos-delay="350">
      <h3 class="box-abajo-titulo">{t['serv.sup.title']}</h3>
      <p class="box-abajo-desc">{t['serv.sup.desc']}</p>
    </div>
  </div>
</div>
</section>

<style>
    .servicios-title{
        display: flex;
        color: var(--color-primary);
        justify-self: center;
        font-size: 2.2rem;
    }
  .servicios-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    height: 100vh;
    padding: 1rem;
  }

  .left-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .box-grande {
    flex: 3;
    border: 2px solid #333;
    background-color: var(--color-primary);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4rem;
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
  }

  .box-grande::after {
    content: '';
    position: absolute;
    top: -3rem;
    right: -3rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(60px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-grande-titulo {
    color: var(--color-white);
    font-size: 1.8rem;
    line-height: 1.2;
  }

  .box-grande-desc {
    color: var(--color-white);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  .boxes-chicos {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .box-chico {
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-chico::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-chico-titulo {
    color: var(--color-white);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .box-chico-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .right-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .boxes-arriba {
    flex: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
  }

  .box-derecho {
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-derecho::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-derecho-titulo {
    color: var(--color-white);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .box-derecho-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .box-abajo {
    flex: 1;
    border: 2px solid #333;
    background-color: var(--color-primary);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .box-abajo::after {
    content: '';
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    background: var(--color-secondary);
    filter: blur(45px);
    opacity: 0.45;
    pointer-events: none;
  }

  .box-abajo-titulo {
    color: var(--color-white);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .box-abajo-desc {
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .servicios-container {
      grid-template-columns: 1fr;
      height: auto;
      padding: 1rem;
      gap: 1rem;
    }

    .left-side {
      display: contents;
    }

    .right-side {
      display: contents;
    }

    .box-grande {
      order: 1;
      min-height: 300px;
    }

    .boxes-chicos {
      order: 2;
      min-height: 150px;
    }

    .boxes-arriba {
      order: 3;
      min-height: 300px;
    }

    .box-abajo {
      order: 4;
      min-height: 150px;
    }
  }

  @media (max-width: 480px) {
    .servicios-title {
      font-size: 1.8rem;
    display: flex;
    justify-content: center;
    }

    .servicios-container {
      padding: 0.5rem;
      gap: 0.75rem;
    }

    .box-grande {
      order: 1;
      min-height: 250px;
    }

    .boxes-chicos {
      display: contents;
    }

    .box-chico {
      min-height: 150px;
    }

    .box-chico:nth-child(1) {
      order: 2;
    }

    .box-chico:nth-child(2) {
      order: 3;
    }

    .boxes-arriba {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: auto;
    }

    .box-derecho {
      min-height: 150px;
    }

    .box-derecho:nth-child(1) {
      order: 4;
    }

    .box-derecho:nth-child(2) {
      order: 5;
    }

    .box-derecho:nth-child(3) {
      order: 6;
    }

    .box-derecho:nth-child(4) {
      order: 7;
    }

    .box-abajo {
      order: 8;
      min-height: 150px;
    }
  }

  @media (min-width: 1440px) {
    .servicios-title {
      font-size: 2.8rem;
      margin-bottom: 0.5rem;
    }

    .servicios-container {
      max-width: 1380px;
      margin: 0 auto;
    }

    .box-grande-titulo { font-size: 2.2rem; }
    .box-grande-desc   { font-size: 1.1rem; }
    .box-chico-titulo  { font-size: 1.4rem; }
    .box-chico-desc    { font-size: 0.95rem; }
    .box-derecho-titulo { font-size: 1.4rem; }
    .box-derecho-desc  { font-size: 0.95rem; }
    .box-abajo-titulo  { font-size: 1.4rem; }
    .box-abajo-desc    { font-size: 0.95rem; }
  }
</style>